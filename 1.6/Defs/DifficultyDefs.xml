<?xml version="1.0" encoding="utf-8" ?>
<Defs>

  <!-- RimBot default difficulty: very forgiving sandbox for AI colonists.
       Based on Peaceful but with slightly more going on. -->
  <DifficultyDef>
    <defName>RimBot</defName>
    <label>RimBot</label>
    <description>A forgiving environment designed for AI-controlled colonists. Threats are minimal, mood is boosted, and resource yields are generous. You can switch to a different difficulty at any time in the game settings.

(*SectionTitle)Settings:(/SectionTitle)

- No raids or big threats
- No extreme weather
- High mood baseline (+15)
- Boosted crop, mine, and research yields
- Very rare disease
- No infestations
- Low food poisoning chance</description>
    <difficulty>0</difficulty>
    <threatScale>0</threatScale>
    <allowBigThreats>false</allowBigThreats>
    <allowIntroThreats>false</allowIntroThreats>
    <peacefulTemples>true</peacefulTemples>
    <allowCaveHives>false</allowCaveHives>
    <allowViolentQuests>false</allowViolentQuests>
    <predatorsHuntHumanlikes>false</predatorsHuntHumanlikes>
    <allowExtremeWeatherIncidents>false</allowExtremeWeatherIncidents>
    <colonistMoodOffset>15</colonistMoodOffset>
    <cropYieldFactor>1</cropYieldFactor>
    <mineYieldFactor>1.5</mineYieldFactor>
    <researchSpeedFactor>1.5</researchSpeedFactor>
    <diseaseIntervalFactor>5</diseaseIntervalFactor>
    <enemyReproductionRateFactor>0</enemyReproductionRateFactor>
    <playerPawnInfectionChanceFactor>0.1</playerPawnInfectionChanceFactor>
    <manhunterChanceOnDamageFactor>0</manhunterChanceOnDamageFactor>
    <deepDrillInfestationChanceFactor>0</deepDrillInfestationChanceFactor>
    <wastepackInfestationChanceFactor>0</wastepackInfestationChanceFactor>
    <nomadicMineableResourcesFactor>1</nomadicMineableResourcesFactor>
    <foodPoisonChanceFactor>0.1</foodPoisonChanceFactor>
    <maintenanceCostFactor>0.5</maintenanceCostFactor>
    <enemyDeathOnDownedChanceFactor>1</enemyDeathOnDownedChanceFactor>
    <adaptationGrowthRateFactorOverZero>0</adaptationGrowthRateFactorOverZero>
    <scariaRotChance>0</scariaRotChance>
    <minThreatPointsRangeCeiling>0</minThreatPointsRangeCeiling>
    <studyEfficiencyFactor>2</studyEfficiencyFactor>
  </DifficultyDef>

</Defs>
